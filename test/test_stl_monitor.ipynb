   "source": [
    "### Basic test signals"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "metadata": {},
   "outputs": [],
   "source": [
    "# One sample\n",
    "sig0 = sr.Signal()\n",
    "sig0.append_sample(0, -1)\n",
    "sig0.append_sample(1., 1)\n",
    "\n",
    "sig1 = sr.Signal()\n",
    "sig1.append_sample(.3, 2)\n",
    "sig1.append_sample(.6, 1.5)\n",
    "sig1.append_sample(1.3, -3)\n",
    "\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Longer signals"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "metadata": {},
   "outputs": [
