   "source": [
    "# Testing monitors\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "True"
      ]
     },
     "execution_count": 5,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "stl_parser = stlrom.STLDriver()\n",
    "stl_parser.parse_string(\"\"\"signal x, y       # declaring signals named 'x' and 'y'\n",
    "param p=0.2, tau=5  # declaring parameters named 'p' and 'q'\n",
    "# Let's add some formulas\n",
    "mu_x := x[t] > p\n",
    "mu_eq := x[t] == p \n",
    "phi_x := ev_[0, tau] ( mu_x )\n",
    "mu_y := y[t] < p \n",
    "mu := mu_x and mu_y \n",
    "phi_y := y[t]>p => ev_[0, tau] (y[t]<p)\n",
    "\"\"\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Helper, to add data to a monitor\n",
    "def add_signals(mon,times, sig_x, sig_y):\n",
    "    for i in range(0, len(times)):\n",
    "        mon.add_sample([times[i],sig_x[i],sig_y[i]])\n",
    "    return mon\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Monitoring phi_x"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [],
   "source": [
    "phi_x = stl_parser.get_monitor(\"phi_x\")\n",
    "phi_x_ltr = stl_parser.get_monitor(\"phi_x\")\n",
    "\n",
    "phi_x = add_signals(phi_x, times, sin_val, overshoot_val)\n",
    "phi_x_ltr = add_signals(phi_x_ltr, times, sin_val, overshoot_val)\n",
    "\n"
   ]
  },
